# Optional storage driver override.
# Leave empty to auto-detect:
# - uses Vercel Blob when BLOB_READ_WRITE_TOKEN is available
# - otherwise uses the filesystem
STORAGE_DRIVER=

# Optional custom upload storage path for filesystem mode.
# Local relative example: UPLOADS_DIR=uploads
# Linux absolute example: UPLOADS_DIR=/srv/cjnet-print/uploads
UPLOADS_DIR=

# Optional Blob key prefix for blob mode.
BLOB_PATH_PREFIX=cjnet-print

# Set by Vercel Blob or manually when using blob mode.
BLOB_READ_WRITE_TOKEN=

# Staff admin access
# In development, the app falls back to simple defaults if these are empty.
# In production, set all three explicitly.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Upload limits (server-side enforcement)
UPLOAD_MAX_FILE_COUNT=20
UPLOAD_MAX_FILE_SIZE_MB=100
UPLOAD_MAX_BATCH_SIZE_MB=500

# Upload limits shown/validated on the client UI (should match server values)
NEXT_PUBLIC_UPLOAD_MAX_FILE_COUNT=20
NEXT_PUBLIC_UPLOAD_MAX_FILE_SIZE_MB=100
NEXT_PUBLIC_UPLOAD_MAX_BATCH_SIZE_MB=500

# Batch status polling rate limit (per client per hour)
BATCH_STATUS_LOOKUP_LIMIT_PER_HOUR=120
